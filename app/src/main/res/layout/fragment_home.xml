<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="Starea ta de sănătate"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Container pentru siluetă și zone clickabile -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="20dp">

            <!-- Silueta umană -->

            <!-- Zona inimii (puls, ECG) -->

            <ImageView
                android:id="@+id/iv_body"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/body_silhouette" />

            <!-- Zona plămânilor (SpO₂) -->

            <!-- Zona pielii (temperatură, umiditate) -->

        </RelativeLayout>

        <!-- Card cu ultimele valori -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Ultimele măsurători"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_last_hr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Puls: -- bpm" />

                <TextView
                    android:id="@+id/tv_last_spo2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SpO₂: -- %" />

                <TextView
                    android:id="@+id/tv_last_temp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Temperatură: -- °C" />

                <TextView
                    android:id="@+id/tv_last_hum"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Umiditate: -- %" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>