PORT=3001

# Origins permise pentru CORS (separat prin virgulă)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5176

# Firebase Database URL
FIREBASE_DATABASE_URL=https://cloudappis-default-rtdb.firebaseio.com

# Opțiunea 1 (local dev): path la service account JSON
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Opțiunea 2 (Cloud Run / CI): service account base64-encoded
# FIREBASE_SERVICE_ACCOUNT_BASE64=eyJhb...
# → generare: base64 -w0 serviceAccountKey.json
